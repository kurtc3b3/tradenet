# UN Comtrade API subscription key (free tier: https://comtradedeveloper.un.org)
# Preview mode works without a key but is limited to 500 records per request.
COMTRADE_SUBSCRIPTION_KEY=

# Default output directory for collected trade flows
DATA_DIR=./data

# Optional HTTP user agent
HTTP_USER_AGENT=tradenet/0.1 (https://github.com/tradenet)

# Minimum seconds between Comtrade API requests (free tier is strict; increase if you hit 429)
COMTRADE_REQUEST_DELAY=1.5

# Retries when Comtrade returns 429/503 before failing
COMTRADE_MAX_RETRIES=8
